APP_NAME=DTV-Ad Monitor API
APP_ENV=development
APP_DEBUG=true
API_V1_PREFIX=/api/v1

DB_HOST=host.docker.internal
DB_PORT=5432
DB_NAME=dtv_ad_monitor
DB_USER=dtv_user
DB_PASSWORD=strongpassword

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

JWT_SECRET=change_this_to_a_long_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://192.168.0.178:3000,http://192.168.0.196:3000
CORS_ORIGIN_REGEX=^http://(localhost|127\.0\.0\.1|192\.168\.\d+\.\d+)(:\d+)?$

KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_FRAMES_TOPIC=dtv.sampled.frames
KAFKA_GROUP_DETECTION=dtv-detection-consumers

ENABLE_AUDIO_MATCHING=true
ENABLE_FRAME_MATCHING=true
ENABLE_CLASSIFIER=false
ENABLE_WATERMARK_DETECTION=false
ENABLE_WEBSOCKET_STREAMING=false
ENABLE_AUTO_VERIFICATION=false

EVIDENCE_RETENTION_DAYS=30
AUTO_DELETE_OLD_EVIDENCE=false

STORAGE_MODE=local
LOCAL_STORAGE_BASE_DIR=storage
LOCAL_UPLOAD_DIR=uploads/advertisements
EVIDENCE_BASE_PATH=evidence
SCREENSHOT_OUTPUT_DIR=evidence/screenshots
CLIP_OUTPUT_DIR=evidence/clips
TEMP_AUDIO_DIR=tmp/audio

FFMPEG_BINARY_PATH=ffmpeg

FRAME_SAMPLE_INTERVAL_SECONDS=2.0
AUDIO_CHUNK_DURATION_SECONDS=3.0
FRAME_RESIZE_WIDTH=320
PREPROCESS_GRAYSCALE=false

FRAME_MATCH_THRESHOLD=0.92
AUDIO_MATCH_THRESHOLD=0.92
HYBRID_MATCH_THRESHOLD=0.85
DUPLICATE_COOLDOWN_SECONDS=60

WORKER_IDLE_SLEEP_SECONDS=3.0
STREAM_RECONNECT_DELAY_SECONDS=5.0
STREAM_MAX_RETRIES=-1
CLIP_DURATION_SECONDS=3.0

S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET_NAME=
S3_REGION=us-east-1